public class Solution {
    public ListNode getIntersectionNode(ListNode headA, ListNode headB) {
        ListNode p1 = headA;
        ListNode p2 = headB;
        while(p1 != p2){//p1指向null就要跳转到headB，p2同理；如果不跳转继续在headA，就会陷入死循环
               p1 = (p1 == null)?headB:p1.next; //三目运算符
                p2 = (p2 == null)?headA:p2.next; 
        }//解题本质就是这个p指针走过的长度是一样的，永远都是m+n，所以p1走完m就要跳出继续走n，p2同理
        return p1;
    }
}
